# Clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
# Optional comma-separated domains for Clerk JWT verification
CLERK_AUTHORIZED_PARTIES=

# Neon
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# Default frontend data API path. On Vercel this should remain /api/db.
VITE_DATA_API_PATH=/api/db

# UploadThing
UPLOADTHING_APP_ID=replace_me
UPLOADTHING_SECRET=sk_live_replace_me
UPLOADTHING_CALLBACK_URL=

# Temporary migration mode.
# Set to true only while keeping legacy PIN login without Clerk tokens.
ALLOW_PIN_AUTH_WITHOUT_CLERK=false
